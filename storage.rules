rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdminClaim() {
      return signedIn() && request.auth.token.role == "admin";
    }

    function isTeacherOwner(teacherId) {
      return signedIn() && request.auth.uid == teacherId;
    }

    match /course-assets/{teacherId}/{courseId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isAdminClaim() || isTeacherOwner(teacherId);
    }

    match /student-imports/{teacherId}/{allPaths=**} {
      allow read, write: if isAdminClaim() || isTeacherOwner(teacherId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
