rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentRole() {
      return currentUser().data.role;
    }

    function isAdmin() {
      return signedIn() && currentRole() == "admin";
    }

    function isTeacher() {
      return signedIn() && currentRole() == "teacher";
    }

    function isStudent() {
      return signedIn() && currentRole() == "student";
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isTeacherOwner() {
      return isTeacher() && (
        resource.data.teacherId == request.auth.uid
        || (
          resource.data.teacherIds is list
          && request.auth.uid in resource.data.teacherIds
        )
      );
    }

    function createsTeacherOwned() {
      return isTeacher() && (
        request.resource.data.teacherId == request.auth.uid
        || (
          request.resource.data.teacherIds is list
          && request.auth.uid in request.resource.data.teacherIds
        )
      );
    }

    function studentCanReadAssignedRecord() {
      return isStudent()
        && resource.data.studentIds is list
        && resource.data.studentIds.hasAny([request.auth.uid]);
    }

    function studentCanReadCourse(courseId) {
      return isStudent()
        && courseId is string
        && get(/databases/$(database)/documents/teacherCourses/$(courseId))
          .data.studentIds.hasAny([request.auth.uid]);
    }

    function studentCanReadTeacherRecord(teacherId) {
      return isStudent()
        && get(/databases/$(database)/documents/students/$(request.auth.uid))
          .data.teacherIds.hasAny([teacherId]);
    }

    function studentCanReadTeacherGradeSubject(teacherId, gradeId, track, subject) {
      let student = get(/databases/$(database)/documents/students/$(request.auth.uid)).data;
      return isStudent()
        && student.teacherIds.hasAny([teacherId])
        && student.gradeId == gradeId
        && (!("track" in student) || student.track == track)
        && (
          student.curriculumSubject == subject
          || (
            student.curriculumSubjects is list
            && subject in student.curriculumSubjects
          )
        );
    }

    function studentCanReadPublishedTeacherGrade(teacherId, gradeId, track, status) {
      let student = get(/databases/$(database)/documents/students/$(request.auth.uid)).data;
      return isStudent()
        && status == "published"
        && student.teacherIds.hasAny([teacherId])
        && student.gradeId == gradeId
        && (
          !("track" in student)
          || track == ""
          || student.track == track
        );
    }

    function studentCanReadLesson(lessonId) {
      let lesson = get(/databases/$(database)/documents/lessons/$(lessonId)).data;
      return isStudent()
        && (
          lesson.status == "published"
          ||
          studentCanReadPublishedTeacherGrade(
            lesson.teacherId,
            lesson.gradeId,
            lesson.track,
            lesson.status
          )
          ||
          studentCanReadTeacherGradeSubject(
            lesson.teacherId,
            lesson.gradeId,
            lesson.track,
            lesson.subject
          )
          || studentCanReadCourse(lesson.courseId)
        );
    }

    function studentCanReadQuiz(quizId) {
      return isStudent()
        && studentCanReadLesson(
          get(/databases/$(database)/documents/quizzes/$(quizId)).data.lessonId
        );
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();

      allow create: if (
          signedIn()
          && request.auth.uid == userId
          && request.resource.data.role == "student"
          && request.resource.data.uid == request.auth.uid
        )
        || (
          isAdmin()
          && request.resource.data.uid == userId
          && request.resource.data.role in ["admin", "teacher", "student"]
        )
        || (
          isTeacher()
          && request.resource.data.uid == userId
          && request.resource.data.role == "student"
          && request.resource.data.createdBy == request.auth.uid
        );

      allow update: if isAdmin()
        || (
          signedIn()
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["displayName", "photoURL", "updatedAt"])
        )
        || (
          signedIn()
          && request.auth.uid == userId
          && (!("username" in resource.data) || resource.data.username == "")
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["username", "updatedAt"])
          && request.resource.data.username is string
        );

      allow delete: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if signedIn();
      allow create: if (
          isAdmin()
          && request.resource.data.role in ["admin", "teacher", "student"]
        )
        || (
          isTeacher()
          && request.resource.data.role == "student"
          && request.resource.data.createdBy == request.auth.uid
        )
        || (
          signedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.role == "student"
        );
      allow update, delete: if isAdmin()
        || (
          isTeacher()
          && resource.data.role == "student"
          && resource.data.createdBy == request.auth.uid
        );
    }

    match /teachers/{teacherId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow list, create, update, delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAdmin()
        || isOwner(resource.data.userId)
        || isOwner(resource.data.studentId)
        || (
          isStudent()
          && (
            resource.data.username == currentUser().data.username
            || resource.data.authEmail == request.auth.token.email
            || resource.data.email == request.auth.token.email
          )
        )
        || isTeacherOwner();
      allow create: if isAdmin() || createsTeacherOwned();
      allow update: if isAdmin() || isTeacherOwner();
      allow delete: if isAdmin() || isTeacherOwner();
    }

    match /specializations/{specializationId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /educationalStages/{stageId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /gradeLevels/{gradeId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /curriculums/{curriculumId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /teacherCourses/{courseId} {
      allow read: if isAdmin()
        || isTeacherOwner()
        || studentCanReadAssignedRecord();
      allow create: if isAdmin() || createsTeacherOwned();
      allow update, delete: if isAdmin() || isTeacherOwner();
    }

    match /courseStudents/{courseStudentId} {
      allow read: if isAdmin()
        || isTeacherOwner()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isAdmin() || createsTeacherOwned();
      allow update, delete: if isAdmin() || isTeacherOwner();
    }

    match /lessons/{lessonId} {
      allow read: if isAdmin()
        || isTeacherOwner()
        || (isStudent() && resource.data.status == "published")
        || studentCanReadPublishedTeacherGrade(
          resource.data.teacherId,
          resource.data.gradeId,
          resource.data.track,
          resource.data.status
        )
        || studentCanReadTeacherGradeSubject(
          resource.data.teacherId,
          resource.data.gradeId,
          resource.data.track,
          resource.data.subject
        )
        || studentCanReadCourse(resource.data.courseId);
      allow create: if isAdmin() || createsTeacherOwned();
      allow update, delete: if isAdmin() || isTeacherOwner();
    }

    match /lessonBlocks/{blockId} {
      allow read: if isAdmin()
        || isTeacherOwner()
        || studentCanReadLesson(resource.data.lessonId);
      allow create: if isAdmin() || createsTeacherOwned();
      allow update, delete: if isAdmin() || isTeacherOwner();
    }

    match /quizzes/{quizId} {
      allow read: if isAdmin()
        || isTeacherOwner()
        || studentCanReadTeacherGradeSubject(
          resource.data.teacherId,
          resource.data.gradeId,
          resource.data.track,
          resource.data.subject
        )
        || studentCanReadCourse(resource.data.courseId)
        || studentCanReadLesson(resource.data.lessonId);
      allow create: if isAdmin() || createsTeacherOwned();
      allow update, delete: if isAdmin() || isTeacherOwner();
    }

    match /quizQuestions/{questionId} {
      allow read: if isAdmin()
        || isTeacherOwner()
        || studentCanReadQuiz(resource.data.quizId);
      allow create: if isAdmin() || createsTeacherOwned();
      allow update, delete: if isAdmin() || isTeacherOwner();
    }

    match /quizOptions/{optionId} {
      allow read: if isAdmin()
        || isTeacherOwner()
        || studentCanReadQuiz(resource.data.quizId);
      allow create: if isAdmin() || createsTeacherOwned();
      allow update, delete: if isAdmin() || isTeacherOwner();
    }

    match /quizAttempts/{attemptId} {
      allow read: if isAdmin()
        || isTeacherOwner()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin()
        || isTeacherOwner()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /quizAnswers/{answerId} {
      allow read: if isAdmin()
        || isTeacherOwner()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /studentProgress/{progressId} {
      allow read: if isAdmin()
        || isTeacherOwner()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow create, update: if isAdmin()
        || isTeacherOwner()
        || (isStudent() && request.resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin()
        || (isTeacher() && (
          resource.data.senderId == request.auth.uid
          || resource.data.targetId == request.auth.uid
          || resource.data.targetType == "allTeachers"
        ))
        || (isStudent() && (
          resource.data.targetId == request.auth.uid
          || resource.data.targetType in ["allStudents", "courseStudents"]
        ));
      allow create: if isAdmin()
        || (isTeacher() && request.resource.data.senderId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isTeacher() && resource.data.senderId == request.auth.uid);
    }

    match /messages/{messageId} {
      allow read: if isAdmin()
        || (signedIn() && (
          resource.data.senderId == request.auth.uid
          || resource.data.receiverId == request.auth.uid
        ));
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid;
      allow update: if signedIn()
        && (
          resource.data.senderId == request.auth.uid
          || resource.data.receiverId == request.auth.uid
        );
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userRole == currentRole();
      allow update, delete: if false;
    }

    match /systemSettings/{settingId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
